{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Castellyn",
  "version": "0.7.1",
  "identifier": "com.danscmax.castellyn",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Castellyn",
        "width": 1100,
        "height": 720,
        "minWidth": 920,
        "minHeight": 560,
        "decorations": false,
        "backgroundColor": "#080c18",
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost; font-src 'self' data:; object-src 'none'; base-uri 'self'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": "v1Compatible",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/danscMax/castellyn/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE1QzhCQTgzRjg3RUQ0NEIKUldSTDFINzRnN3JJcFhzYlJlekwzS0RGRFcvUnZicE1FbVF2M3hCczUvWFA0bEltRHBNU25uYkgK"
    }
  }
}
